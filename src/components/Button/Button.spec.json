{
  "name": "Button",
  "description": "Primary interactive element for triggering actions.",
  "variants": ["primary", "secondary", "ghost", "danger"],
  "sizes": ["sm", "md", "lg"],
  "tokens": {
    "background": "--bs-color-primary-default",
    "backgroundHover": "--bs-color-primary-hover",
    "text": "--bs-color-text-on-primary",
    "borderRadius": "--bs-radius-md",
    "paddingX": "--bs-spacing-4",
    "paddingY": "--bs-spacing-2",
    "fontSize": "--bs-typography-label-size",
    "fontWeight": "--bs-typography-label-weight"
  },
  "states": ["default", "hover", "active", "disabled", "loading"],
  "accessibility": {
    "role": "button",
    "minTouchTarget": "44px"
  }
}
